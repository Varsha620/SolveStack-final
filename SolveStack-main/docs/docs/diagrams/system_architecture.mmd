        CollabService["Collaboration & Squads"]:::backend
        ScraperManager["Scraper Service Worker"]:::backend
    end

    subgraph "Data Storage"
        PG["PostgreSQL"]:::db
        Vectors["pgvector (Semantic Search)"]:::db
